# Adam Selene Environment Variables
# Copy this file to .env and fill in your values.
# Run: cp .env.example .env

# ── Required ──────────────────────────────────────────
OPENROUTER_API_KEY=

# ── Telegram (if enabled) ────────────────────────────
TELEGRAM_BOT_TOKEN=

# ── Slack (if enabled) ───────────────────────────────
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_SIGNING_SECRET=

# ── Optional ─────────────────────────────────────────
FIRECRAWL_API_KEY=

# ── GitHub (App auth preferred over PAT) ─────────────
# GitHub App auth: never expires, no manual rotation
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_B64=   # base64 -w 0 key.pem
GITHUB_USERNAME=
# PAT fallback (used only if App creds absent):
GITHUB_TOKEN=
