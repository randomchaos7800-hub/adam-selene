# SmartAgent Environment Variables
# Copy this file to .env and fill in your values.
# Run: cp .env.example .env

# ── Required ──────────────────────────────────────────
OPENROUTER_API_KEY=

# ── Telegram (if enabled) ────────────────────────────
TELEGRAM_BOT_TOKEN=

# ── Slack (if enabled) ───────────────────────────────
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_SIGNING_SECRET=

# ── Optional ─────────────────────────────────────────
FIRECRAWL_API_KEY=
GITHUB_TOKEN=
